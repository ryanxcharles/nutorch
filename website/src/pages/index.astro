---
import CodeBlock from "../components/CodeBlock.astro";
import Base from "../layouts/Base.astro";
import { INSTALL as install } from "../lib/install";

const heroDemo = `a=$(torch tensor '[1,2,3]')
b=$(torch tensor '[4,5,6]')
torch add $a $b | torch value
# [5.0,7.0,9.0]   computed on the GPU`;

const heroDemoNu = `let a = ([1 2 3] | nutorch tensor)
let b = ([4 5 6] | nutorch tensor)
$a | nutorch add $b | nutorch value
# [5.0, 7.0, 9.0] — a native list, on the GPU`;

const bashDemo = `m=$(torch randn '[3,3]')
torch mm $m $m | torch mean | torch value
# matrix product, then mean — one pipeline`;

const nuDemo = `use nutorch.nu *
let t = ([[1 2] [3 4]] | nutorch tensor)
$t | nutorch mm $t | nutorch value
# native table out`;

const trainDemo = `w=$(torch randn '[3]' --requires_grad)
loss=$(torch mul $w $w | torch sum)
torch backward $loss
torch grad $w | torch value`;

const features = [
  {
    title: "GPU-only, by design",
    body:
      "Every tensor lives on the Apple-silicon GPU via Metal. There is no "
      + "device option — that is the point of the library.",
  },
  {
    title: "Any shell is first-class",
    body:
      "Handles are plain strings on stdout. Real POSIX pipelines compose in "
      + "bash, zsh, and fish; Nushell gets a native structured-data module.",
  },
  {
    title: "Autograd and neural nets",
    body:
      "Gradients flow through any pipeline. Modules, optimizers, training "
      + "loops, and safetensors interchange with PyTorch — from the shell.",
  },
  {
    title: "PyTorch fidelity",
    body:
      "Command names, argument order, defaults, and broadcasting semantics "
      + "match PyTorch wherever possible. 185 ops and counting.",
  },
];
---

<Base
  title="nutorch — GPU tensors for every shell"
  description="GPU tensors for every shell — PyTorch semantics on Apple-silicon Metal, piped through bash, zsh, fish, or Nushell."
>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-6 pt-16 pb-12 sm:pt-24">
    <div class="flex flex-col items-center gap-10 sm:flex-row sm:gap-14">
      <div class="relative shrink-0">
        <div class="hero-glow absolute -inset-14" aria-hidden="true"></div>
        <img
          src="/images/nutorch-hero.png"
          srcset="/images/nutorch-hero.png 1x, /images/nutorch-hero@2x.png 2x"
          alt="The nutorch logo: a green nautilus shell with a flame"
          width="300"
          height="300"
          class="relative w-52 sm:w-72"
        />
      </div>
      <div class="min-w-0 flex-1 text-center sm:text-left">
        <h1
          class="font-display text-4xl font-bold tracking-tight text-balance sm:text-5xl"
        >
          GPU tensors for <span class="text-primary">every</span> shell
        </h1>
        <p class="mt-4 text-lg text-muted">
          Tensors live on your GPU. Your shell passes handles. Pipes do the
          rest.
        </p>
        <div class="mt-6 text-left">
          <div class="mb-2 flex gap-1.5" role="tablist" aria-label="Shell">
            <button
              id="hero-tab-posix"
              role="tab"
              aria-selected="true"
              aria-controls="hero-panel-posix"
              data-shell="posix"
              class="hero-shell-tab rounded-md border border-border px-2.5 py-1 font-mono text-xs text-muted transition-colors"
            >bash / zsh</button>
            <button
              id="hero-tab-nu"
              role="tab"
              aria-selected="false"
              aria-controls="hero-panel-nu"
              data-shell="nu"
              class="hero-shell-tab rounded-md border border-border px-2.5 py-1 font-mono text-xs text-muted transition-colors"
            >Nushell</button>
          </div>
          <div
            id="hero-panel-posix"
            role="tabpanel"
            aria-labelledby="hero-tab-posix"
          >
            <CodeBlock code={heroDemo} lang="bash" />
          </div>
          <div
            id="hero-panel-nu"
            role="tabpanel"
            aria-labelledby="hero-tab-nu"
            hidden
          >
            <CodeBlock code={heroDemoNu} lang="nu" />
          </div>
        </div>
        <p class="mt-3 text-sm text-muted">
          PyTorch semantics on Apple-silicon Metal — from bash, zsh, fish, or
          Nushell.
        </p>
        <div
          class="mt-6 flex flex-wrap items-center justify-center gap-4 sm:justify-start"
        >
          <a
            href="#install"
            class="rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-background transition-opacity hover:opacity-85"
          >Install</a>
          <a
            href="https://github.com/nutorch/nutorch"
            class="rounded-lg border border-border px-5 py-2.5 text-sm font-semibold transition-colors hover:border-muted"
          >GitHub</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Install -->
  <section id="install" class="mx-auto max-w-5xl scroll-mt-8 px-6 py-12">
    <h2 class="font-display text-2xl font-bold tracking-tight">
      Three commands
    </h2>
    <p class="mt-2 text-muted">
      A prebuilt bottle pours in seconds — no Python, no Rust, no checkout.
    </p>
    <div class="relative mt-6">
      <CodeBlock code={install} lang="bash" />
      <button
        id="copy-install"
        type="button"
        aria-label="Copy install commands"
        data-copy={install}
        class="absolute top-3 right-3 rounded-md border border-border bg-surface px-2.5 py-1 text-xs font-medium text-muted transition-colors hover:text-foreground"
      >copy</button>
    </div>
  </section>

  <!-- Demos -->
  <section class="mx-auto max-w-5xl px-6 py-12">
    <h2 class="font-display text-2xl font-bold tracking-tight">See it run</h2>
    <p class="mt-2 text-muted">
      The daemon starts itself on the first command and owns the GPU; your
      shell just passes handles around.
    </p>
    <div class="mt-6 grid gap-6 lg:grid-cols-2">
      <div>
        <h3 class="mb-3 font-mono text-sm font-medium text-muted">bash</h3>
        <CodeBlock code={bashDemo} lang="bash" />
      </div>
      <div>
        <h3 class="mb-3 font-mono text-sm font-medium text-muted">nushell</h3>
        <CodeBlock code={nuDemo} lang="nu" />
      </div>
    </div>
    <div class="mt-6">
      <h3 class="mb-3 font-mono text-sm font-medium text-muted">
        autograd, in your terminal
      </h3>
      <CodeBlock code={trainDemo} lang="bash" />
    </div>
  </section>

  <!-- Features -->
  <section class="mx-auto max-w-5xl px-6 py-12 pb-20">
    <div class="grid gap-5 sm:grid-cols-2">
      {
        features.map((f) => (
          <div class="rounded-xl border border-border bg-surface p-6">
            <h3 class="font-display text-lg font-bold">{f.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{f.body}</p>
          </div>
        ))
      }
    </div>
  </section>
</Base>

<script>
  // Hero shell tabs: swap panels, persist the visitor's shell choice.
  const shellTabs = document.querySelectorAll<HTMLButtonElement>("[data-shell]");
  const applyShell = (shell: string) => {
    for (const tab of shellTabs) {
      const active = tab.dataset.shell === shell;
      tab.setAttribute("aria-selected", String(active));
      document
        .getElementById(`hero-panel-${tab.dataset.shell}`)
        ?.toggleAttribute("hidden", !active);
    }
  };
  let savedShell = null;
  try {
    savedShell = localStorage.getItem("hero-shell");
  } catch {}
  if (savedShell === "nu" || savedShell === "posix") applyShell(savedShell);
  for (const tab of shellTabs) {
    tab.addEventListener("click", () => {
      applyShell(tab.dataset.shell!);
      try {
        localStorage.setItem("hero-shell", tab.dataset.shell!);
      } catch {}
    });
  }

  const button = document.getElementById("copy-install");
  button?.addEventListener("click", async () => {
    const text = button.dataset.copy;
    if (!text) return;
    await navigator.clipboard.writeText(text);
    button.textContent = "copied";
    setTimeout(() => (button.textContent = "copy"), 1500);
  });
</script>
